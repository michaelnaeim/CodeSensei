GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GITHUB_TOKEN=
# Local dev uses SQLite. On Railway, add a Postgres plugin and set this to
# its DATABASE_URL (postgres:// is auto-normalized).
DATABASE_URL=sqlite:///./codesensei.db
# Comma-separated frontend origins allowed via CORS (your Vercel URL in prod).
# Use * to allow any origin.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CHALLENGE_PASS_THRESHOLD=80
QUIZ_PASS_THRESHOLD=70
MAX_FILES_TO_INDEX=200
MAX_FILE_SIZE_BYTES=150000
